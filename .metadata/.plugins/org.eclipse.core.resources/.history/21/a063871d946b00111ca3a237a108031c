<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <title>E-commerce • Catálogo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="./css/loja.css">
</head>
<body>
  <header>
    <div class="wrap bar">
      <h1>Minha Loja</h1>
      <div class="spacer"></div>
      <input id="q" type="search" placeholder="Buscar produtos..." />
      <select id="ord">
        <option value="">Ordenar</option>
        <option value="preco_asc">Preço: menor → maior</option>
        <option value="preco_desc">Preço: maior → menor</option>
        <option value="nome_asc">Nome: A → Z</option>
        <option value="nome_desc">Nome: Z → A</option>
      </select>
      <a href="carrinho.html" class="pill" title="Itens no carrinho">
        🛒 Carrinho <span id="cartCount" class="badge">0</span>
      </a>
    </div>
  </header>

  <main class="wrap">
    <div id="status" class="loading muted">Carregando catálogo…</div>
    <section id="grid" class="grid" hidden></section>
    <div id="empty" class="empty" hidden>Nenhum produto encontrado.</div>
    <div id="error" class="err" hidden>Não foi possível carregar o catálogo.</div>
  </main>

  <footer>© <span id="year"></span> Minha Loja</footer>

  <template id="cardTmpl">
    <article class="card">
      <img class="thumb" loading="lazy" alt="">
      <div class="content">
        <div class="title"></div>
        <div class="row">
          <div class="price"></div>
          <div class="stock"></div>
        </div>
        <button class="btn addBtn">Adicionar ao carrinho</button>
      </div>
    </article>
  </template>

  <script src="./js/loja.js"></script>
</body>
</html>
